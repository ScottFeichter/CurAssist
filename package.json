{
  "name": "curassist-backend",
  "version": "1.0.0",
  "description": "Backend for CurAssist workflow app",
  "main": "dist/entry.js",
  "scripts": {
    "build": "tsc && tsc-alias && cp -r src/views dist/ && cp -r src/public dist/",
    "start": "node dist/entry.js",
    "dev": "npm run build && nodemon dist/entry.js",
    "watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.0",
    "express": "^4.18.2",
    "winston": "^3.15.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "nodemon": "^3.0.1",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.3.3"
  }
}
